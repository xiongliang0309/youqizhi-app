[
  {
    "title": "咏鹅",
    "author": "骆宾王",
    "content": [
      "鹅，鹅，鹅，",
      "曲项向天歌。",
      "白毛浮绿水，",
      "红掌拨清波。"
    ],
    "keywords": "goose white water",
    "audio": "/audio/poems/咏鹅.mp3"
  },
  {
    "title": "静夜思",
    "author": "李白",
    "content": [
      "床前明月光，",
      "疑是地上霜。",
      "举头望明月，",
      "低头思故乡。"
    ],
    "keywords": "moon night window",
    "audio": "/audio/poems/静夜思.mp3"
  },
  {
    "title": "春晓",
    "author": "孟浩然",
    "content": [
      "春眠不觉晓，",
      "处处闻啼鸟。",
      "夜来风雨声，",
      "花落知多少。"
    ],
    "keywords": "spring bird flower",
    "image": "/images/poems/春晓.jpg",
    "audio": "/audio/poems/春晓.mp3"
  },
  {
    "title": "悯农",
    "author": "李绅",
    "content": [
      "锄禾日当午，",
      "汗滴禾下土。",
      "谁知盘中餐，",
      "粒粒皆辛苦。"
    ],
    "keywords": "farmer field rice",
    "image": "/images/poems/悯农.jpg",
    "audio": "/audio/poems/悯农.mp3"
  },
  {
    "title": "登鹳雀楼",
    "author": "王之涣",
    "content": [
      "白日依山尽，",
      "黄河入海流。",
      "欲穷千里目，",
      "更上一层楼。"
    ],
    "keywords": "sunset river tower",
    "image": "/images/poems/登鹳雀楼.jpg",
    "audio": "/audio/poems/登鹳雀楼.mp3"
  },
  {
    "title": "江雪",
    "author": "柳宗元",
    "content": [
      "千山鸟飞绝，",
      "万径人踪灭。",
      "孤舟蓑笠翁，",
      "独钓寒江雪。"
    ],
    "keywords": "snow river boat",
    "image": "/images/poems/江雪.jpg",
    "audio": "/audio/poems/江雪.mp3"
  },
  {
    "title": "寻隐者不遇",
    "author": "贾岛",
    "content": [
      "松下问童子，",
      "言师采药去。",
      "只在此山中，",
      "云深不知处。"
    ],
    "keywords": "pine mountain cloud",
    "image": "/images/poems/寻隐者不遇.jpg",
    "audio": "/audio/poems/寻隐者不遇.mp3"
  },
  {
    "title": "画",
    "author": "王维",
    "content": [
      "远看山有色，",
      "近听水无声。",
      "春去花还在，",
      "人来鸟不惊。"
    ],
    "keywords": "landscape painting",
    "image": "/images/poems/画.jpg",
    "audio": "/audio/poems/画.mp3"
  },
  {
    "title": "风",
    "author": "李峤",
    "content": [
      "解落三秋叶，",
      "能开二月花。",
      "过江千尺浪，",
      "入竹万竿斜。"
    ],
    "keywords": "wind bamboo wave",
    "audio": "/audio/poems/风.mp3"
  },
  {
    "title": "相思",
    "author": "王维",
    "content": [
      "红豆生南国，",
      "春来发几枝。",
      "愿君多采撷，",
      "此物最相思。"
    ],
    "keywords": "red bean spring",
    "audio": "/audio/poems/相思.mp3"
  },
  {
    "title": "绝句",
    "author": "杜甫",
    "content": [
      "两个黄鹂鸣翠柳，",
      "一行白鹭上青天。",
      "窗含西岭千秋雪，",
      "门泊东吴万里船。"
    ],
    "keywords": "willow bird snow",
    "image": "/images/poems/绝句.jpg",
    "audio": "/audio/poems/绝句.mp3"
  },
  {
    "title": "草",
    "author": "白居易",
    "content": [
      "离离原上草，",
      "一岁一枯荣。",
      "野火烧不尽，",
      "春风吹又生。"
    ],
    "keywords": "grass field fire",
    "image": "/images/poems/草.jpg",
    "audio": "/audio/poems/草.mp3"
  },
  {
    "title": "游子吟",
    "author": "孟郊",
    "content": [
      "慈母手中线，",
      "游子身上衣。",
      "临行密密缝，",
      "意恐迟迟归。",
      "谁言寸草心，",
      "报得三春晖。"
    ],
    "keywords": "mother sewing clothes",
    "image": "/images/poems/游子吟.jpg",
    "audio": "/audio/poems/游子吟.mp3"
  },
  {
    "title": "早发白帝城",
    "author": "李白",
    "content": [
      "朝辞白帝彩云间，",
      "千里江陵一日还。",
      "两岸猿声啼不住，",
      "轻舟已过万重山。"
    ],
    "keywords": "boat river mountain",
    "image": "/images/poems/早发白帝城.jpg",
    "audio": "/audio/poems/早发白帝城.mp3"
  },
  {
    "title": "望庐山瀑布",
    "author": "李白",
    "content": [
      "日照香炉生紫烟，",
      "遥看瀑布挂前川。",
      "飞流直下三千尺，",
      "疑是银河落九天。"
    ],
    "keywords": "waterfall mountain mist",
    "image": "/images/poems/望庐山瀑布.jpg",
    "audio": "/audio/poems/望庐山瀑布.mp3"
  },
  {
    "title": "回乡偶书",
    "author": "贺知章",
    "content": [
      "少小离家老大回，",
      "乡音无改鬓毛衰。",
      "儿童相见不相识，",
      "笑问客从何处来。"
    ],
    "keywords": "old man hometown",
    "image": "/images/poems/回乡偶书.jpg",
    "audio": "/audio/poems/回乡偶书.mp3"
  },
  {
    "title": "赠汪伦",
    "author": "李白",
    "content": [
      "李白乘舟将欲行，",
      "忽闻岸上踏歌声。",
      "桃花潭水深千尺，",
      "不及汪伦送我情。"
    ],
    "keywords": "boat river peach",
    "image": "/images/poems/赠汪伦.jpg",
    "audio": "/audio/poems/赠汪伦.mp3"
  },
  {
    "title": "黄鹤楼送孟浩然之广陵",
    "author": "李白",
    "content": [
      "故人西辞黄鹤楼，",
      "烟花三月下扬州。",
      "孤帆远影碧空尽，",
      "唯见长江天际流。"
    ],
    "keywords": "river boat tower",
    "audio": "/audio/poems/黄鹤楼送孟浩然之广陵.mp3"
  },
  {
    "title": "九月九日忆山东兄弟",
    "author": "王维",
    "content": [
      "独在异乡为异客，",
      "每逢佳节倍思亲。",
      "遥知兄弟登高处，",
      "遍插茱萸少一人。"
    ],
    "keywords": "mountain autumn homesick",
    "image": "/images/poems/九月九日忆山东兄弟.jpg",
    "audio": "/audio/poems/九月九日忆山东兄弟.mp3"
  },
  {
    "title": "咏柳",
    "author": "贺知章",
    "content": [
      "碧玉妆成一树高，",
      "万条垂下绿丝绦。",
      "不知细叶谁裁出，",
      "二月春风似剪刀。"
    ],
    "keywords": "willow tree spring",
    "image": "/images/poems/咏柳.jpg",
    "audio": "/audio/poems/咏柳.mp3"
  },
  {
    "title": "小池",
    "author": "杨万里",
    "content": [
      "泉眼无声惜细流，",
      "树阴照水爱晴柔。",
      "小荷才露尖尖角，",
      "早有蜻蜓立上头。"
    ],
    "keywords": "lotus dragonfly pond",
    "audio": "/audio/poems/小池.mp3"
  },
  {
    "title": "所见",
    "author": "袁枚",
    "content": [
      "牧童骑黄牛，",
      "歌声振林樾。",
      "意欲捕鸣蝉，",
      "忽然闭口立。"
    ],
    "keywords": "cow boy forest",
    "audio": "/audio/poems/所见.mp3"
  },
  {
    "title": "村居",
    "author": "高鼎",
    "content": [
      "草长莺飞二月天，",
      "拂堤杨柳醉春烟。",
      "儿童散学归来早，",
      "忙趁东风放纸鸢。"
    ],
    "keywords": "kite spring children",
    "image": "/images/poems/村居.jpg",
    "audio": "/audio/poems/村居.mp3"
  },
  {
    "title": "鹿柴",
    "author": "王维",
    "content": [
      "空山不见人，",
      "但闻人语响。",
      "返景入深林，",
      "复照青苔上。"
    ],
    "keywords": "forest moss sunlight",
    "image": "/images/poems/鹿柴.jpg",
    "audio": "/audio/poems/鹿柴.mp3"
  },
  {
    "title": "竹里馆",
    "author": "王维",
    "content": [
      "独坐幽篁里，",
      "弹琴复长啸。",
      "深林人不知，",
      "明月来相照。"
    ],
    "keywords": "bamboo moon zither",
    "image": "/images/poems/竹里馆.jpg",
    "audio": "/audio/poems/竹里馆.mp3"
  },
  {
    "title": "夜宿山寺",
    "author": "李白",
    "content": [
      "危楼高百尺，",
      "手可摘星辰。",
      "不敢高声语，",
      "恐惊天上人。"
    ],
    "keywords": "star tower night",
    "image": "/images/poems/夜宿山寺.jpg",
    "audio": "/audio/poems/夜宿山寺.mp3"
  },
  {
    "title": "江畔独步寻花",
    "author": "杜甫",
    "content": [
      "黄四娘家花满蹊，",
      "千朵万朵压枝低。",
      "留连戏蝶时时舞，",
      "自在娇莺恰恰啼。"
    ],
    "keywords": "flower butterfly garden",
    "image": "/images/poems/江畔独步寻花.jpg",
    "audio": "/audio/poems/江畔独步寻花.mp3"
  },
  {
    "title": "山行",
    "author": "杜牧",
    "content": [
      "远上寒山石径斜，",
      "白云生处有人家。",
      "停车坐爱枫林晚，",
      "霜叶红于二月花。"
    ],
    "keywords": "maple autumn mountain",
    "image": "/images/poems/山行.jpg",
    "audio": "/audio/poems/山行.mp3"
  },
  {
    "title": "清明",
    "author": "杜牧",
    "content": [
      "清明时节雨纷纷，",
      "路上行人欲断魂。",
      "借问酒家何处有？",
      "牧童遥指杏花村。"
    ],
    "keywords": "rain village shepherd",
    "audio": "/audio/poems/清明.mp3"
  },
  {
    "title": "枫桥夜泊",
    "author": "张继",
    "content": [
      "月落乌啼霜满天，",
      "江枫渔火对愁眠。",
      "姑苏城外寒山寺，",
      "夜半钟声到客船。"
    ],
    "keywords": "boat night bell",
    "audio": "/audio/poems/枫桥夜泊.mp3"
  },
  {
    "title": "悯农(其一)",
    "author": "李绅",
    "content": [
      "春种一粒粟，",
      "秋收万颗子。",
      "四海无闲田，",
      "农夫犹饿死。"
    ],
    "keywords": "field harvest grain",
    "image": "/images/poems/悯农(其一).jpg",
    "audio": "/audio/poems/悯农(其一).mp3"
  },
  {
    "title": "江南",
    "author": "汉乐府",
    "content": [
      "江南可采莲，",
      "莲叶何田田。",
      "鱼戏莲叶间。",
      "鱼戏莲叶东，",
      "鱼戏莲叶西。"
    ],
    "keywords": "lotus fish river",
    "image": "/images/poems/江南.jpg",
    "audio": "/audio/poems/江南.mp3"
  },
  {
    "title": "敕勒歌",
    "author": "北朝民歌",
    "content": [
      "敕勒川，阴山下。",
      "天似穹庐，笼盖四野。",
      "天苍苍，野茫茫，",
      "风吹草低见牛羊。"
    ],
    "keywords": "grassland sheep sky",
    "image": "/images/poems/敕勒歌.jpg",
    "audio": "/audio/poems/敕勒歌.mp3"
  },
  {
    "title": "凉州词",
    "author": "王翰",
    "content": [
      "葡萄美酒夜光杯，",
      "欲饮琵琶马上催。",
      "醉卧沙场君莫笑，",
      "古来征战几人回？"
    ],
    "keywords": "wine desert horse",
    "image": "/images/poems/凉州词.jpg",
    "audio": "/audio/poems/凉州词.mp3"
  },
  {
    "title": "塞下曲",
    "author": "卢纶",
    "content": [
      "月黑雁飞高，",
      "单于夜遁逃。",
      "欲将轻骑逐，",
      "大雪满弓刀。"
    ],
    "keywords": "snow night archer",
    "image": "/images/poems/塞下曲.jpg",
    "audio": "/audio/poems/塞下曲.mp3"
  },
  {
    "title": "逢雪宿芙蓉山主人",
    "author": "刘长卿",
    "content": [
      "日暮苍山远，",
      "天寒白屋贫。",
      "柴门闻犬吠，",
      "风雪夜归人。"
    ],
    "keywords": "snow dog house",
    "image": "/images/poems/逢雪宿芙蓉山主人.jpg",
    "audio": "/audio/poems/逢雪宿芙蓉山主人.mp3"
  },
  {
    "title": "渡汉江",
    "author": "宋之问",
    "content": [
      "岭外音书断，",
      "经冬复历春。",
      "近乡情更怯，",
      "不敢问来人。"
    ],
    "keywords": "river road traveler",
    "image": "/images/poems/渡汉江.jpg",
    "audio": "/audio/poems/渡汉江.mp3"
  },
  {
    "title": "秋浦歌",
    "author": "李白",
    "content": [
      "白发三千丈，",
      "缘愁似个长。",
      "不知明镜里，",
      "何处得秋霜。"
    ],
    "keywords": "mirror white hair",
    "audio": "/audio/poems/秋浦歌.mp3"
  },
  {
    "title": "独坐敬亭山",
    "author": "李白",
    "content": [
      "众鸟高飞尽，",
      "孤云独去闲。",
      "相看两不厌，",
      "只有敬亭山。"
    ],
    "keywords": "mountain bird cloud",
    "image": "/images/poems/独坐敬亭山.jpg",
    "audio": "/audio/poems/独坐敬亭山.mp3"
  },
  {
    "title": "宿建德江",
    "author": "孟浩然",
    "content": [
      "移舟泊烟渚，",
      "日暮客愁新。",
      "野旷天低树，",
      "江清月近人。"
    ],
    "keywords": "river boat moon",
    "image": "/images/poems/宿建德江.jpg",
    "audio": "/audio/poems/宿建德江.mp3"
  },
  {
    "title": "从军行",
    "author": "王昌龄",
    "content": [
      "黄沙百战穿金甲，",
      "不破楼兰终不还。"
    ],
    "keywords": "desert soldier armor",
    "audio": "/audio/poems/从军行.mp3"
  },
  {
    "title": "出塞",
    "author": "王昌龄",
    "content": [
      "秦时明月汉时关，",
      "万里长征人未还。",
      "但使龙城飞将在，",
      "不教胡马度阴山。"
    ],
    "keywords": "moon wall horse",
    "audio": "/audio/poems/出塞.mp3"
  },
  {
    "title": "送元二使安西",
    "author": "王维",
    "content": [
      "渭城朝雨浥轻尘，",
      "客舍青青柳色新。",
      "劝君更尽一杯酒，",
      "西出阳关无故人。"
    ],
    "keywords": "wine willow rain",
    "image": "/images/poems/送元二使安西.jpg",
    "audio": "/audio/poems/送元二使安西.mp3"
  },
  {
    "title": "送灵澈上人",
    "author": "刘长卿",
    "content": [
      "苍苍竹林寺，",
      "杳杳钟声晚。",
      "荷笠带斜阳，",
      "青山独归远。"
    ],
    "keywords": "temple bamboo bell",
    "image": "/images/poems/送灵澈上人.jpg",
    "audio": "/audio/poems/送灵澈上人.mp3"
  },
  {
    "title": "听筝",
    "author": "李端",
    "content": [
      "鸣筝金粟柱，",
      "素手玉房前。",
      "欲得周郎顾，",
      "时时误拂弦。"
    ],
    "keywords": "zither hand music",
    "image": "/images/poems/听筝.jpg",
    "audio": "/audio/poems/听筝.mp3"
  },
  {
    "title": "玉阶怨",
    "author": "李白",
    "content": [
      "玉阶生白露，",
      "夜久侵罗袜。",
      "却下水晶帘，",
      "玲珑望秋月。"
    ],
    "keywords": "moon curtain night",
    "image": "/images/poems/玉阶怨.jpg",
    "audio": "/audio/poems/玉阶怨.mp3"
  },
  {
    "title": "杂诗",
    "author": "王维",
    "content": [
      "君自故乡来，",
      "应知故乡事。",
      "来日绮窗前，",
      "寒梅著花未？"
    ],
    "keywords": "plum flower window",
    "image": "/images/poems/杂诗.jpg",
    "audio": "/audio/poems/杂诗.mp3"
  },
  {
    "title": "问刘十九",
    "author": "白居易",
    "content": [
      "绿蚁新醅酒，",
      "红泥小火炉。",
      "晚来天欲雪，",
      "能饮一杯无？"
    ],
    "keywords": "wine fire snow",
    "image": "/images/poems/问刘十九.jpg",
    "audio": "/audio/poems/问刘十九.mp3"
  },
  {
    "title": "秋夜寄邱员外",
    "author": "韦应物",
    "content": [
      "怀君属秋夜，",
      "散步咏凉天。",
      "空山松子落，",
      "幽人应未眠。"
    ],
    "keywords": "night mountain autumn",
    "audio": "/audio/poems/秋夜寄邱员外.mp3"
  },
  {
    "title": "乐游原",
    "author": "李商隐",
    "content": [
      "向晚意不适，",
      "驱车登古原。",
      "夕阳无限好，",
      "只是近黄昏。"
    ],
    "keywords": "sunset hill grass",
    "audio": "/audio/poems/乐游原.mp3"
  },
  {
    "title": "乌衣巷",
    "author": "刘禹锡",
    "content": [
      "朱雀桥边野草花，",
      "乌衣巷口夕阳斜。",
      "旧时王谢堂前燕，",
      "飞入寻常百姓家。"
    ],
